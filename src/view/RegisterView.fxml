<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.Pane?>
<?import javafx.scene.text.Font?>

<AnchorPane fx:id="anchorRegister" prefHeight="400.0" prefWidth="400.0" stylesheets="@styles/MainStyle.css" xmlns="http://javafx.com/javafx/23.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="view.RegisterViewController">
   <children>
      <Label layoutX="14.0" layoutY="100.0" text="Usuario">
         <font>
            <Font size="20.0" />
         </font>
      </Label>
      <TextField fx:id="txtUser" layoutX="14.0" layoutY="129.0" prefHeight="40.0" prefWidth="352.0" />
      <Label layoutX="14.0" layoutY="179.0" text="Senha">
         <font>
            <Font size="20.0" />
         </font>
      </Label>
      <PasswordField fx:id="txtPassword" layoutX="14.0" layoutY="208.0" prefHeight="40.0" prefWidth="352.0" />
      <Label layoutX="14.0" layoutY="260.0" text="Confirmação senha">
         <font>
            <Font size="20.0" />
         </font>
      </Label>
      <PasswordField fx:id="txtPasswordConf" layoutX="14.0" layoutY="289.0" prefHeight="40.0" prefWidth="352.0" />
      <Label fx:id="labelMenssage" layoutX="14.0" layoutY="63.0" prefHeight="29.0" prefWidth="352.0" />
      <Button fx:id="btnSave" layoutX="14.0" layoutY="343.0" mnemonicParsing="false" onAction="#onBtnRegisterUser" prefHeight="43.0" prefWidth="170.0" text="Salvar">
         <font>
            <Font size="20.0" />
         </font>
      </Button>
      <Button fx:id="btnExit" layoutX="216.0" layoutY="343.0" mnemonicParsing="false" onAction="#onBtnExiet" prefHeight="43.0" prefWidth="170.0" text="Voltar">
         <font>
            <Font size="20.0" />
         </font>
      </Button>
      <Pane layoutY="14.0" prefHeight="43.0" prefWidth="371.0" styleClass="title-back">
         <children>
            <Label layoutX="14.0" layoutY="-4.0" prefHeight="29.0" prefWidth="235.0" text="Novo Usuario">
               <font>
                  <Font size="36.0" />
               </font>
            </Label>
         </children>
      </Pane>
   </children>
</AnchorPane>
